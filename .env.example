# ============================================================
# BehaviorCI environment configuration
# Every variable below has a FREE default. You do not need to
# pay for anything to run this project end to end.
# ============================================================

# --- Database ---
# Default: local SQLite file, zero setup, zero cost.
# To use free hosted Postgres instead (e.g. Supabase / Neon free tier),
# set this to something like:
# postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./behaviorci.db

# --- LLM Judge (the AI evaluator) ---
# Mode options: "ollama" (free, local, default) | "anthropic" | "openai"
JUDGE_MODE=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# Only required if JUDGE_MODE=anthropic or JUDGE_MODE=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Embeddings (for behavioral drift detection) ---
# Mode options: "local" (free, sentence-transformers, default) | "openai"
EMBED_MODE=local
EMBED_LOCAL_MODEL=all-MiniLM-L6-v2

# --- Test runner ---
MAX_CONCURRENT_EVALUATIONS=10
REGRESSION_SCORE_THRESHOLD=0.10
DRIFT_DISTANCE_THRESHOLD=0.15

# --- GitHub integration (optional, only needed for PR comments) ---
GITHUB_TOKEN=
